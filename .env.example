# Path to the source Excel file (e.g. Mentor Data.xlsx or tests/fixtures/synthetic_mentor_data.xlsx)
MENTOR_EXCEL_PATH=tests/fixtures/synthetic_mentor_data.xlsx

# Database Connection URL (Postgres in production, fallback to SQLite for local sandbox dev)
DATABASE_URL=sqlite:///./database.db
TEST_DATABASE_URL=sqlite:///./database.db

# FastAPI Secret Key
SECRET_KEY=supersecretkey123
